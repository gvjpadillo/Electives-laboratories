<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Resume - Gwyneth Vera J. Padillo</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #eef2f5;
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            line-height: 1.45;
            color: #1e2a3e;
            padding: 2rem 1rem;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        /* Resume card container – prints as one page */
        .resume {
            max-width: 960px;
            width: 100%;
            background: white;
            border-radius: 16px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            transition: all 0.2s;
        }

        /* inner spacing */
        .resume-inner {
            padding: 2rem 2rem 2rem 2rem;
        }

        /* header area */
        .name {
            font-size: 2.4rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: #0a2942;
            margin-bottom: 0.5rem;
            line-height: 1.2;
        }

        .contact-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem 2rem;
            background: #f8fafc;
            padding: 0.9rem 1rem;
            border-radius: 20px;
            margin: 1rem 0 1.5rem 0;
            font-size: 0.9rem;
            border: 1px solid #e2edf2;
        }

        .contact-item {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: #2c4b6c;
            font-weight: 450;
        }

        .contact-item i.emoji {
            font-weight: 400;
            opacity: 0.8;
        }

        hr {
            border: none;
            border-top: 2px solid #cbdde6;
            margin: 0.8rem 0 1.2rem 0;
        }

        /* section headings */
        .section-title {
            font-size: 1.3rem;
            font-weight: 700;
            color: #1f6392;
            border-left: 5px solid #2c7cb6;
            padding-left: 0.9rem;
            margin: 1.5rem 0 0.9rem 0;
            letter-spacing: -0.2px;
        }

        .section-title:first-of-type {
            margin-top: 0;
        }

        /* education blocks */
        .edu-entry {
            margin-bottom: 0.9rem;
        }

        .edu-degree {
            font-weight: 700;
            font-size: 1rem;
            color: #0f3b5c;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
        }

        .edu-date {
            font-weight: 500;
            color: #5c6f87;
            font-size: 0.85rem;
        }

        .edu-school {
            font-weight: 500;
            color: #2c5a7a;
            margin-top: 0.1rem;
            font-size: 0.9rem;
        }

        .edu-detail {
            font-size: 0.92rem;
            color: #2c3e4e;
            margin-top: 0.2rem;
        }

        /* skills grid */
        .skills-list {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem 1rem;
            margin-top: 0.3rem;
            list-style: none;
        }

        .skills-list li {
            background: #eef3fc;
            padding: 0.3rem 1rem;
            border-radius: 30px;
            font-size: 0.85rem;
            font-weight: 500;
            color: #1a5d8c;
        }

        /* experience entries */
        .exp-item {
            margin-bottom: 1.3rem;
        }

        .exp-header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 0.25rem;
        }

        .exp-role {
            font-weight: 700;
            font-size: 1rem;
            color: #0e3b5a;
        }

        .exp-date {
            font-size: 0.8rem;
            font-weight: 500;
            color: #6f8eaa;
        }

        .exp-subrole {
            font-weight: 600;
            font-size: 0.9rem;
            color: #2a6b9c;
            margin-top: 0.4rem;
        }

        .exp-desc {
            font-size: 0.88rem;
            color: #2c3e50;
            margin-top: 0.25rem;
            margin-left: 0.2rem;
            line-height: 1.4;
        }

        .bullet-list {
            margin-top: 0.25rem;
            padding-left: 1.2rem;
        }

        .bullet-list li {
            margin-bottom: 0.25rem;
            font-size: 0.88rem;
        }

        /* achievements & languages */
        .achievement-text, .lang-text {
            font-size: 0.92rem;
            background: #f9fbfd;
            padding: 0.5rem 1rem;
            border-radius: 14px;
            display: inline-block;
            width: auto;
            margin-top: 0.2rem;
        }

        .lang-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin-top: 0.3rem;
        }

        .lang-cat {
            background: #ffffff;
            border: 1px solid #dce7ef;
            border-radius: 20px;
            padding: 0.5rem 1rem;
            flex: 1 1 200px;
        }

        .lang-cat strong {
            color: #1f6392;
            font-weight: 700;
            display: block;
            font-size: 0.85rem;
            margin-bottom: 0.3rem;
        }

        .lang-cat span {
            font-size: 0.85rem;
            color: #2c4f6e;
        }

        /* fine print spacing */
        .last-update {
            text-align: right;
            font-size: 0.7rem;
            color: #96adc2;
            margin-top: 1.8rem;
            border-top: 1px solid #e2edf2;
            padding-top: 0.8rem;
        }

        /* print adjustments - one page */
        @media print {
            body {
                background: white;
                padding: 0;
                margin: 0;
            }
            .resume {
                box-shadow: none;
                border-radius: 0;
                max-width: 100%;
            }
            .resume-inner {
                padding: 0.4in 0.3in;
            }
            .contact-bar {
                background: #f4f7fa;
                border: 0.5px solid #ccc;
                break-inside: avoid;
            }
            .section-title {
                margin-top: 0.8rem;
            }
            .last-update {
                display: none;
            }
            /* ensure no page break inside sections */
            .edu-entry, .exp-item, .skills-list, .lang-grid {
                break-inside: avoid;
            }
        }

        /* responsive touch */
        @media (max-width: 550px) {
            .resume-inner {
                padding: 1.25rem;
            }
            .name {
                font-size: 1.9rem;
            }
            .contact-bar {
                gap: 0.7rem;
            }
        }
    </style>
</head>
